rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    function ownsResource() {
      return isSignedIn() && resource.data.userId == request.auth.uid;
    }

    function ownsIncoming() {
      return isSignedIn() && request.resource.data.userId == request.auth.uid;
    }

    match /users/{uid} {
      allow read, write: if isOwner(uid);
    }

    match /user_preferences/{uid} {
      allow read, write: if isOwner(uid);
    }

    match /nutrition_entries/{docId} {
      // Allow reads when the requested doc id is prefixed with the
      // caller's uid (this app uses `<uid>_<date>` doc ids). This lets
      // listeners on not-yet-existing docs return empty instead of
      // permission-denied. Existing-doc reads still require ownership.
      allow read: if isSignedIn() &&
        (docId.matches('^' + request.auth.uid + '_.*') ||
         (resource != null && resource.data.userId == request.auth.uid));
      allow delete: if ownsResource();
      allow create: if ownsIncoming();
      allow update: if ownsResource() && ownsIncoming();
    }

    match /scanned_products/{docId} {
      allow read: if isSignedIn();
      allow create: if ownsIncoming();
      allow update, delete: if ownsResource();
    }
  }
}
